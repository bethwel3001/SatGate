# ==============================================================================
# SatGo Backend Configuration (.env)
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Database Configuration
# ------------------------------------------------------------------------------
# PostgreSQL connection string is required.
# Format: postgres://[user]:[password]@[host]:[port]/[database_name]
#
# To run PostgreSQL locally via Docker:
#   docker run --name satgo-postgres -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=satgo -p 5432:5432 -d postgres
#
DATABASE_URL=postgres://postgres:postgres@localhost:5432/satgo

# ------------------------------------------------------------------------------
# 2. Server Configuration
# ------------------------------------------------------------------------------
PORT=8080
RUST_LOG=info

# ------------------------------------------------------------------------------
# 3. JWT Authentication Configuration
# ------------------------------------------------------------------------------
# Secret key used to sign/verify owner authentication tokens.
# Change this to a secure random string in production.
JWT_SECRET=your_jwt_signing_secret_here

# ------------------------------------------------------------------------------
# 4. Lightning Network Provider Configuration (Mavapay or Alby)
# ------------------------------------------------------------------------------
# The API key and Base URL of your Lightning Service Provider (LSP).
# The backend checks both MAVAPAY_ and LN_ prefixes.

# Option A: Mavapay API Integration
MAVAPAY_API_KEY=your_mavapay_api_key_here
MAVAPAY_BASE_URL=https://staging.api.mavapay.co/api/v1

# Option B: Alby API Integration (Alternative)
# LN_API_KEY=your_alby_bearer_token_here
# LN_API_URL=https://api.getalby.com

# ------------------------------------------------------------------------------
# 5. Webhook Security Configuration
# ------------------------------------------------------------------------------
# Secret token used to verify signature headers of incoming payments webhooks.
# The backend checks both LIGHTNING_WEBHOOK_SECRET and WEBHOOK_SECRET.
LIGHTNING_WEBHOOK_SECRET=your_lightning_webhook_signing_secret_here
